{
  "compilerOptions": {
    "target": "ES2018",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true, // 如果严格模式导致报错，可临时关闭
    "jsx": "preserve",
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true, // 兼容 CommonJS 模块
    "lib": [
      "ES2018",
      "DOM"
    ],
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@mat-touch-ui/*": [
        "src/components/*"
      ]
    },
    // 类型声明输出配置
    "declaration": true,
    "declarationDir": "dist/types",
    "emitDeclarationOnly": true,
    // 关闭自动导入类型，避免冲突
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "allowSyntheticDefaultImports": true, // 允许默认导入非默认模块
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "example"
  ]
}