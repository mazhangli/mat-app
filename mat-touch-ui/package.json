{
  "name": "mat-touch-ui",
  "private": true,
  "version": "26.1.0",
  "description": "基于Vue3+TS通用控件库(同方卫康)",
  "type": "module",
  "author": "MHT",
  "license": "MIT",
  "main": "./dist/mat-touch-ui.cjs.js",
  "umd:main": "dist/mat-touch-ui.umd.js",
  "module": "./dist/mat-touch-ui.esm.js",
  "types": "./dist/index.d.ts",
  "keywords": [
    "vue3",
    "vite",
    "typescript",
    "vant",
    "element-plus",
    "ui-library",
    "mat-touch-ui"
  ],
  "exports": {
    ".": {
      "import": "./dist/mat-touch-ui.es.js",
      "require": "./dist/mat-touch-ui.cjs.js",
      "umd": "./dist/mat-touch-ui.umd.js",
      "types": "./dist/index.d.ts"
    },
    "./*": "./*"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -p tsconfig.json --emitDeclarationOnly --outDir dist/types && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "amfe-flexible": "^2.2.1",
    "element-plus": "^2.13.0",
    "postcss-pxtorem": "^6.1.0",
    "vant": "^4.9.22",
    "vue": "^3.5.26"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/runtime-core": "^3.5.26",
    "@vue/tsconfig": "^0.8.1",
    "less": "^4.5.1",
    "less-loader": "^12.3.0",
    "rolldown-vite": "^7.3.0",
    "rollup-plugin-dts": "^5.3.0",
    "sass": "^1.97.1",
    "sass-embedded": "^1.97.1",
    "terser": "^5.44.1",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^20.3.0",
    "unplugin-vue-components": "^30.0.0",
    "vite": "^7.2.4",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-dts": "^4.5.4",
    "vue-tsc": "^3.2.2"
  }
}
